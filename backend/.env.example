JSON_BODY_LIMIT=10mb
WEBHOOK_JSON_BODY_LIMIT=1mb
TRUST_PROXY=false
REQUIRE_HTTPS=false
RUNTIME_DIAGNOSTICS_ENABLED=true
SLOW_REQUEST_THRESHOLD_MS=750
DIAGNOSTICS_LOG_INTERVAL_MS=300000
EVENT_LOOP_RESOLUTION_MS=20
EVENT_LOOP_DELAY_WARN_MS=120
MEMORY_USAGE_WARN_MB=768
UNUSUAL_TRAFFIC_THRESHOLD_PER_MINUTE=120
MAX_URL_LENGTH=2048
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=5000
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10
SIGNUP_RATE_LIMIT_WINDOW_MS=3600000
SIGNUP_RATE_LIMIT_MAX=5
RECOVERY_RATE_LIMIT_WINDOW_MS=900000
RECOVERY_RATE_LIMIT_MAX=10
READ_RATE_LIMIT_WINDOW_MS=60000
READ_RATE_LIMIT_MAX=5000
WRITE_RATE_LIMIT_WINDOW_MS=900000
WRITE_RATE_LIMIT_MAX=2000
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=20
BLOCK_AUTOMATION_USER_AGENTS=false
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
EMAIL_VERIFICATION_TOKEN_MINUTES=60
PASSWORD_RESET_TOKEN_MINUTES=30
