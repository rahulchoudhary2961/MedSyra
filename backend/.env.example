PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:replace-with-strong-password@localhost:5432/healthcare_saas
DB_APPLICATION_NAME=medsyra-api
DB_POOL_MAX=15
DB_MAX_USES=7500
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=0
DB_QUERY_TIMEOUT_MS=0
DB_LOCK_TIMEOUT_MS=0
DB_IDLE_IN_TRANSACTION_SESSION_TIMEOUT_MS=0
JWT_SECRET=replace-with-at-least-32-characters-random-secret
JWT_EXPIRES_IN=1h
AUTH_COOKIE_NAME=medsyra_session
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
FILE_STORAGE_PROVIDER=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_REGION=auto
REDIS_URL=redis://localhost:6379
CACHE_DEFAULT_TTL_SECONDS=60
